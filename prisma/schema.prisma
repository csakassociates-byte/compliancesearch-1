// ComplianceSearch.in — Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Existing Models ──────────────────────────────────────────────────────────

model ComplianceRule {
  id               String   @id @default(cuid())
  ruleKey          String   @unique
  name             String
  shortName        String
  category         String
  authority        String
  description      String
  howToComply      String
  frequency        String
  dueDate          String?
  penalty          String?
  registrationLink String?
  priority         String
  isActive         Boolean  @default(true)
  tags             String
  conditionJson    String
  documentsJson    String   @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model CalendarEvent {
  id           String    @id @default(cuid())
  title        String
  description  String?
  category     String
  authority    String
  recurrence   String    @default("monthly")
  dueDay       Int?
  dueMonth     Int?
  specificDate DateTime?
  penalty      String?
  link         String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model BlogPost {
  id            String        @id @default(cuid())
  title         String
  slug          String        @unique
  content       String
  excerpt       String
  category      String        @default("general")
  tags          String        @default("")
  authorName    String
  authorEmail   String
  authorPhone   String
  status        String        @default("pending")
  rejectionNote String?
  adminNotes    String?
  views         Int           @default(0)
  publishedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  comments      BlogComment[]
  likes         BlogLike[]
}

model BlogComment {
  id         String        @id @default(cuid())
  postId     String
  post       BlogPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentId   String?
  parent     BlogComment?  @relation("Replies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies    BlogComment[] @relation("Replies")
  authorName String
  content    String
  createdAt  DateTime      @default(now())
}

model BlogLike {
  id        String   @id @default(cuid())
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  visitorId String
  createdAt DateTime @default(now())

  @@unique([postId, visitorId])
}

model IFSCBranch {
  id       String  @id @default(cuid())
  ifsc     String  @unique
  bank     String
  bankCode String
  branch   String
  address  String?
  city     String?
  district String?
  state    String?

  @@index([bank])
  @@index([bankCode])
  @@index([city])
  @@index([state])
}

model CompanyProfile {
  id                  String            @id @default(cuid())
  cin                 String            @unique
  companyName         String
  regAddress          String?
  entityType          String?
  email               String?
  rocName             String?
  status              String?
  isListed            Boolean           @default(false)
  sourceFile          String?
  mobile              String?
  gstNumber           String?
  incorporationDate   String?
  paidUpCapital       String?
  authorisedCapital   String?
  registrationNumber  String?
  dateOfLastAGM       String?
  dateOfBalanceSheet  String?
  categoryOfCompany   String?
  subcategory         String?
  classOfCompany      String?
  jurisdiction        String?
  smallCompany        Boolean           @default(false)
  uploadedBy          String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  directors           CompanyDirector[]
  charges             CompanyCharge[]
}

model CompanyDirector {
  id          String         @id @default(cuid())
  companyId   String
  company     CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  din         String?
  name        String
  designation String?
  category    String?
  appointedAt String?
  ceasedAt    String?
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model CompanyCharge {
  id             String         @id @default(cuid())
  companyId      String
  company        CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  chargeId       String?
  holderName     String
  dateOfCreation String?
  amount         String?
  address        String?
  isSatisfied    Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Notice {
  id          String   @id @default(cuid())
  title       String
  summary     String
  content     String
  authority   String   @default("MCA")
  noticeType  String   @default("notification")
  refNumber   String?
  actName     String?
  issuedDate  DateTime @default(now())
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Auth Models (csi_ prefix) ───────────────────────────────────────────────

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  passwordHash  String?
  plan          String     @default("free")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  sessions      Session[]
  otps          OTP[]
  companies     Company[]
  documents     Document[]

  @@map("csi_users")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("csi_sessions")
}

model OTP {
  id        String   @id @default(cuid())
  email     String
  code      String
  purpose   String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, purpose])
  @@map("csi_otps")
}

model Company {
  id                String     @id @default(cuid())
  userId            String
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cin               String?
  companyName       String
  regAddress        String?
  entityType        String?
  incorporationDate String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  documents         Document[]

  @@index([userId])
  @@map("csi_companies")
}

model Document {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId     String?
  company       Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  type          String
  title         String
  companyName   String?
  financialYear String?
  meetingDate   String?
  formDataJson  String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([companyId])
  @@map("csi_documents")
}
